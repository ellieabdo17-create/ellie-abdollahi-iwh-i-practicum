doctype html
html
  head
    title= title
  body
    h1= title

    a(href="/") Return to the homepage

    form(action="/update-cobj" method="POST")
      label First Name
      input(type="text" name="firstname" required)

      br
      br

      label Last Name
      input(type="text" name="lastname" required)

      br
      br

      label Email
      input(type="email" name="email" required)

      br
      br

      label Customer Name
      input(type="text" name="customer_name" required)

      br
      br

      label License Type
      select(name="license_type" required)
        option(value="JPRO") JPRO
        option(value="NextStep") NextStep
        option(value="ShopPulse") ShopPulse
        option(value="TripVision") TripVision

      br
      br

      label Expiration Date
      input(type="date" name="expiration_date" required)

      br
      br

      button(type="submit") Create Contact